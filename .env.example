# ── LLM provider configuration ───────────────────────────────────────────
# Proximal uses litellm under the hood. Pick a provider and set its
# model + credentials below.  The provider-specific model string is
# automatically converted to litellm format by Settings.get_litellm_model().
#
# Supported providers: ollama, openai, anthropic

PROVIDER_NAME=ollama # must be one of: ollama, openai, anthropic

# Ollama configuration
OLLAMA_BASE_URL=http://localhost:8080 # must be specified if using ollama provider
OLLAMA_MODEL=llama3:70b-instruct # must be specified if using ollama provider

# OpenAI configuration
OPENAI_API_KEY=sk-... # must be specified if using openai provider
OPENAI_BASE_URL=https://api.openai.com/v1 # can be used to override default
OPENAI_MODEL=gpt-4o-mini # can be used to override default

# Anthropic configuration
ANTHROPIC_API_KEY=sk-... # must be specified if using anthropic provider
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1 # can be used to override default
ANTHROPIC_MODEL=claude-3-haiku # can be used to override default

# ── API authentication (optional) ────────────────────────────────────────
# If not set, the API is open for local development.
# PROXIMAL_API_KEY=your-secret-api-key-here

# ── API server configuration (optional, defaults shown) ─────────────────
# API_HOST=0.0.0.0
# API_PORT=7315
# API_WORKERS=1

# ── Session configuration (optional, defaults shown) ────────────────────
# SESSION_TIMEOUT_HOURS=1
# MAX_CLARIFICATIONS=2

# ── Redis (optional, recommended for production distributed sessions) ───
# REDIS_URL=redis://localhost:6379

# ── LLM configuration (optional, defaults shown) ────────────────────────
# LLM_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=3
# LLM_RETRY_MIN_WAIT=4
# LLM_RETRY_MAX_WAIT=10

# ── Rate limiting (optional, defaults shown) ─────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=10

# ── Logging (optional, defaults shown) ───────────────────────────────────
# LOG_LEVEL=INFO

# ── Calendar provider (optional, defaults shown) ─────────────────────────
# One of: stub, google, outlook.  "stub" uses an in-memory store for dev.
# CALENDAR_PROVIDER=stub

# ── Notification channels (optional) ─────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=noreply@example.com
# NOTIFICATION_EMAIL_TO=you@example.com

# ── Voice backend (optional, defaults shown) ──────────────────────────────
# VOICE_BACKEND=local
